# Copy to .env after your new Supabase project is ready.
# Do NOT commit real secrets. This file is a template only.

# --- Supabase (Project Settings → API) ---
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_PUBLIC_KEY"

# Set to "true" to display scores from optimize-bullet alignment_snapshot (Phase 1c).
# When false, client deterministic scorer remains authoritative (production default).
# VITE_USE_ALIGNMENT_SNAPSHOT="false"

# Resume QA shadow — logs sanitized QA summary after calibrated resume assembly (default off).
# VITE_ENABLE_RESUME_QA_SHADOW="false"

# Resume AST shadow — logs sanitized AST parse/comparison after resume intake + assembly (default off).
# VITE_ENABLE_RESUME_AST_SHADOW="false"

VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_PUBLIC_KEY"

# --- Stripe (Dashboard → Developers → API keys) ---
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
